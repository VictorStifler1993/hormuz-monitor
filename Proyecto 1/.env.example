# === APIs de noticias (opcionales, RSS funciona sin keys) ===
GNEWS_API_KEY=tu_key_de_gnews
NEWSAPI_KEY=tu_key_de_newsapi

# === API de precios (opcional, yfinance funciona sin key) ===
ALPHA_VANTAGE_KEY=tu_key_de_alphavantage

# === Email para notificaciones ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
EMAIL_FROM=tu_email@gmail.com
EMAIL_PASSWORD=tu_app_password_de_gmail
EMAIL_TO=destinatario1@email.com,destinatario2@email.com

# === Umbrales de notificación ===
RELEVANCE_THRESHOLD=0.85
ESCALATION_THRESHOLD=0.7

# === Logging ===
LOG_LEVEL=INFO
